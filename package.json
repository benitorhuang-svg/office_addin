{
  "name": "office-addin-taskpane",
  "version": "0.0.1",
  "engines": {
    "node": ">=25.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OfficeDev/Office-Addin-TaskPane.git"
  },
  "license": "MIT",
  "config": {
    "app_to_debug": "word",
    "app_type_to_debug": "desktop",
    "dev_server_port": 3001
  },
  "bin": {
    "nexus": "./scripts/nexus.mjs"
  },
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "build:server": "esbuild backend/ecosystems/server-entry.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist-server/index.mjs --packages=external --tree-shaking=true --minify-syntax",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p backend/tsconfig.json",
    "typecheck:watch": "tsc --noEmit -p tsconfig.json --watch",
    "dev-server": "webpack serve --mode development",
    "lint": "eslint .",
    "prettier": "office-addin-lint prettier",
    "start": "npm run dev",
    "start:prod": "node scripts/patch-copilot-sdk.mjs && node dist-server/index.mjs",
    "start:addin": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "start:server": "node --watch --experimental-transform-types backend/ecosystems/server-entry.ts",
    "dev": "node scripts/patch-copilot-sdk.mjs && node scripts/dev-win.mjs",
    "docker:up": "npx nexus up",
    "nexus": "node scripts/nexus.mjs"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.2.0",
    "@google/gemini-cli": "^0.35.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@_davideast/stitch-mcp": "^0.5.1",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@github/copilot": "^1.0.11",
    "@inquirer/editor": "^5.0.10",
    "@inquirer/prompts": "^8.3.2",
    "@microsoft/m365agentstoolkit-cli": "^1.1.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^25.5.0",
    "@types/node-fetch": "^2.6.13",
    "@types/office-js": "^1.0.585",
    "@types/office-runtime": "^1.0.36",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@typescript-eslint/utils": "^8.57.2",
    "ajv": "^8.18.0",
    "ajv-keywords": "^5.1.0",
    "babel-loader": "^10.1.1",
    "body-parser": "^2.2.2",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "copy-webpack-plugin": "^14.0.0",
    "core-js": "^3.49.0",
    "css-loader": "^7.1.4",
    "esbuild": "^0.27.4",
    "eslint-plugin-office-addins": "^4.0.6",
    "external-editor": "^3.1.0",
    "file-loader": "^6.2.0",
    "framer-motion": "^12.38.0",
    "globals": "^17.4.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.6",
    "lucide-react": "^1.7.0",
    "marked": "^17.0.5",
    "mocha": "^11.7.5",
    "office-addin-cli": "^2.0.6",
    "office-addin-debugging": "^6.0.6",
    "office-addin-dev-certs": "^2.0.6",
    "office-addin-dev-settings": "^3.0.6",
    "office-addin-lint": "^3.0.6",
    "office-addin-manifest": "^2.1.2",
    "office-addin-prettier-config": "^2.0.1",
    "os-browserify": "^0.3.0",
    "process": "^0.11.10",
    "source-map-loader": "^5.0.0",
    "style-loader": "^4.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3",
    "workbox-webpack-plugin": "^7.4.0"
  },
  "prettier": "office-addin-prettier-config",
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Edge versions"
  ],
  "overrides": {
    "diff": ">=3.5.1",
    "serialize-javascript": ">=7.0.2",
    "tmp": "0.2.5",
    "glob": "^13.0.6",
    "rimraf": "^6.0.1",
    "sourcemap-codec": "npm:@jridgewell/sourcemap-codec@^1.4.15",
    "inflight": "^1.0.6",
    "source-map": "0.7.4",
    "node-domexception": "file:./infra/mocks/node-domexception",
    "domexception": "file:./infra/mocks/node-domexception",
    "deep-diff": "file:./infra/mocks/deep-diff",
    "keytar": "file:./infra/mocks/keytar",
    "@types/express": "^4.17.25",
    "@tootallnate/once": "^3.0.1"
  }
}
