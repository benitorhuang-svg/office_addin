{
  "name": "office-addin-taskpane",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.0.0 <26.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OfficeDev/Office-Addin-TaskPane.git"
  },
  "license": "MIT",
  "config": {
    "app_to_debug": "word",
    "app_type_to_debug": "desktop",
    "dev_server_port": 3001
  },
  "bin": {
    "nexus": "./src/infra/scripts/nexus.mjs"
  },
  "scripts": {
    "build": "node src/infra/scripts/sync-skills.mjs && webpack --mode production",
    "build:dev": "node src/infra/scripts/sync-skills.mjs && webpack --mode development",
    "build:server": "esbuild src/server.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist-server/index.mjs --packages=external --tree-shaking=true --minify-syntax",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:watch": "tsc --noEmit -p tsconfig.json --watch",
    "dev-server": "webpack serve --mode development",
    "lint": "eslint src",
    "prettier": "office-addin-lint prettier",
    "start": "npm run dev",
    "start:prod": "node src/infra/scripts/core/patch-copilot-sdk.mjs && node dist-server/index.mjs",
    "start:addin": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "start:server": "node --watch --experimental-transform-types src/server.ts",
    "dev": "node src/infra/scripts/core/patch-copilot-sdk.mjs && node src/infra/scripts/dev-win.mjs",
    "docker:up": "npx nexus up",
    "nexus": "node src/infra/scripts/nexus.mjs",
    "test:backend": "jest --testPathPatterns=src --coverage",
    "test:ci": "node --experimental-vm-modules node_modules/jest-cli/bin/jest.js --testPathPatterns=src --passWithNoTests",
    "test:backend:watch": "jest --testPathPatterns=src --watch",
    "prepare": "husky"
  },
  "dependencies": {
    "@fluentui/web-components": "^2.6.1",
    "@github/copilot-sdk": "^0.2.0",
    "@google/gemini-cli": "^0.35.1",
    "chromadb": "^3.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@_davideast/stitch-mcp": "^0.5.1",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@github/copilot": "^1.0.11",
    "@inquirer/editor": "^5.0.10",
    "@inquirer/prompts": "^8.3.2",
    "@microsoft/m365agentstoolkit-cli": "^1.1.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/node-fetch": "^2.6.13",
    "@types/office-js": "^1.0.585",
    "@types/office-runtime": "^1.0.36",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@typescript-eslint/utils": "^8.57.2",
    "ajv": "^8.18.0",
    "ajv-keywords": "^5.1.0",
    "babel-loader": "^10.1.1",
    "body-parser": "^2.2.2",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "copy-webpack-plugin": "^14.0.0",
    "core-js": "^3.49.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "esbuild": "^0.27.4",
    "eslint-plugin-office-addins": "^4.0.6",
    "external-editor": "^3.1.0",
    "file-loader": "^6.2.0",
    "globals": "^17.4.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.6",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "json5": "^2.2.3",
    "lint-staged": "^16.4.0",
    "marked": "^17.0.5",
    "office-addin-cli": "^2.0.6",
    "office-addin-debugging": "^6.0.6",
    "office-addin-dev-certs": "^2.0.6",
    "office-addin-dev-settings": "^3.0.6",
    "office-addin-lint": "^3.0.6",
    "office-addin-manifest": "^2.1.2",
    "office-addin-prettier-config": "^2.0.1",
    "os-browserify": "^0.3.0",
    "process": "^0.11.10",
    "source-map-loader": "^5.0.0",
    "style-loader": "^4.0.0",
    "supertest": "^7.2.2",
    "terser-webpack-plugin": "^5.4.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3",
    "workbox-webpack-plugin": "^7.4.0"
  },
  "prettier": "office-addin-prettier-config",
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Edge versions"
  ],
  "overrides": {
    "diff": ">=3.5.1",
    "serialize-javascript": ">=7.0.2",
    "tmp": "0.2.5",
    "glob": "^13.0.6",
    "rimraf": "^6.0.1",
    "sourcemap-codec": "npm:@jridgewell/sourcemap-codec@^1.4.15",
    "inflight": "^1.0.6",
    "source-map": "0.7.4",
    "node-domexception": "file:src/infra/mocks/node-domexception",
    "domexception": "file:src/infra/mocks/node-domexception",
    "deep-diff": "file:src/infra/mocks/deep-diff",
    "keytar": "file:src/infra/mocks/keytar",
    "@types/express": "^4.17.25",
    "@tootallnate/once": "^3.0.1"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "src/**/*.{js,mjs,cjs}": [
      "eslint --fix --max-warnings=0"
    ]
  }
}
