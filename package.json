{
  "name": "office-addin-taskpane",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/OfficeDev/Office-Addin-TaskPane.git"
  },
  "license": "MIT",
  "config": {
    "app_to_debug": "word",
    "app_type_to_debug": "desktop",
    "dev_server_port": 3000
  },
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "dev-server": "webpack serve --mode development",
    "postinstall": "node scripts/patch-copilot-sdk.mjs",
    "lint": "office-addin-lint check",
    "lint:fix": "office-addin-lint fix",
    "prettier": "office-addin-lint prettier",
    "signin": "office-addin-dev-settings m365-account login",
    "signout": "office-addin-dev-settings m365-account logout",
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "watch": "webpack --mode development --watch",
    "start:server": "tsx watch server/index.ts",
    "test": "node --import tsx node_modules/mocha/bin/mocha.js \"server/tests/**/*.ts\" --timeout 5000",
    "dev": "node scripts/dev.mjs"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.32",
    "core-js": "^3.36.0",
    "marked": "^17.0.5",
    "regenerator-runtime": "^0.14.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.25.4",
    "@babel/preset-typescript": "^7.23.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@inquirer/editor": "^5.0.10",
    "@inquirer/prompts": "^8.3.2",
    "@microsoft/m365agentstoolkit-cli": "^1.1.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/marked": "^5.0.2",
    "@types/node": "^20.19.37",
    "@types/node-fetch": "^2.6.7",
    "@types/office-js": "^1.0.377",
    "@types/office-runtime": "^1.0.35",
    "@types/supertest": "^7.2.0",
    "babel-loader": "^9.1.3",
    "body-parser": "^1.20.2",
    "concurrently": "^8.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.1.4",
    "eslint-plugin-office-addins": "^4.0.3",
    "express": "^4.18.2",
    "external-editor": "^3.1.0",
    "file-loader": "^6.2.0",
    "globals": "^17.4.0",
    "html-loader": "^5.0.0",
    "html-webpack-plugin": "^5.6.0",
    "mocha": "^11.7.5",
    "node-fetch": "^2.6.7",
    "office-addin-cli": "^2.0.3",
    "office-addin-debugging": "^6.0.6",
    "office-addin-dev-certs": "^2.0.3",
    "office-addin-dev-settings": "^3.0.6",
    "office-addin-lint": "^3.0.3",
    "office-addin-manifest": "^2.0.3",
    "office-addin-prettier-config": "^2.0.1",
    "os-browserify": "^0.3.0",
    "process": "^0.11.10",
    "source-map-loader": "^5.0.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.4.2",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.3"
  },
  "prettier": "office-addin-prettier-config",
  "browserslist": [
    "last 2 versions",
    "ie 11"
  ],
  "overrides": {
    "tmp": "0.2.5"
  }
}
