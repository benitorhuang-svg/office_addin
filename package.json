{
  "name": "office-addin-taskpane",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/OfficeDev/Office-Addin-TaskPane.git"
  },
  "license": "MIT",
  "config": {
    "app_to_debug": "word",
    "app_type_to_debug": "desktop",
    "dev_server_port": 3000
  },
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "dev-server": "webpack serve --mode development",
    "lint": "office-addin-lint check",
    "lint:fix": "office-addin-lint fix",
    "prettier": "office-addin-lint prettier",
    "signin": "office-addin-dev-settings m365-account login",
    "signout": "office-addin-dev-settings m365-account logout",
    "start": "npm run dev",
    "start:addin": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "watch": "webpack --mode development --watch",
    "start:server": "tsx watch server/ecosystems/server-entry.ts",
    "test": "node --no-warnings --import tsx node_modules/mocha/bin/mocha.js \"server/tests/**/*.ts\" --timeout 5000",
    "dev": "node scripts/patch-copilot-sdk.mjs && node scripts/dev-win.mjs",
    "dev:original": "node scripts/dev.mjs"
  },
  "dependencies": {
    "core-js": "^3.49.0",
    "marked": "^17.0.5",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@github/copilot": "^1.0.11",
    "@google/gemini-cli": "^0.34.0",
    "@inquirer/editor": "^5.0.10",
    "@inquirer/prompts": "^8.3.2",
    "@microsoft/m365agentstoolkit-cli": "^1.1.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/marked": "^6.0.0",
    "@types/node": "^25.5.0",
    "@types/node-fetch": "^2.6.13",
    "@types/office-js": "^1.0.584",
    "@types/office-runtime": "^1.0.36",
    "@types/supertest": "^7.2.0",
    "@github/copilot-sdk": "^0.2.0",
    "@tailwindcss/postcss": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "css-loader": "^7.1.4",
    "esbuild": "^0.27.4",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.2.1",
    "style-loader": "^4.0.0",
    "babel-loader": "^10.1.1",
    "body-parser": "^2.2.2",
    "concurrently": "^9.2.1",
    "copy-webpack-plugin": "^14.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "eslint-plugin-office-addins": "^4.0.6",
    "express": "^5.2.1",
    "external-editor": "^3.1.0",
    "file-loader": "^6.2.0",
    "globals": "^17.4.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.6",
    "mocha": "^11.7.5",
    "node-fetch": "^3.3.2",
    "office-addin-cli": "^2.0.6",
    "office-addin-debugging": "^6.0.6",
    "office-addin-dev-certs": "^2.0.6",
    "office-addin-dev-settings": "^3.0.6",
    "office-addin-lint": "^3.0.6",
    "office-addin-manifest": "^2.1.2",
    "office-addin-prettier-config": "^2.0.1",
    "os-browserify": "^0.3.0",
    "process": "^0.11.10",
    "source-map-loader": "^5.0.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "prettier": "office-addin-prettier-config",
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Edge versions"
  ],
  "overrides": {
    "tmp": "0.2.5"
  }
}
