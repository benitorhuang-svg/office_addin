# ══════════════════════════════════════════════════════════════
# WordAgent Environment Configuration - Example Template
# ══════════════════════════════════════════════════════════════
# Copy this to .env (not committed to git) for local development.
#
# This project supports 4 ACP (Agent Communication Protocol) connection methods.
# See copilot_sdk_connection_methods/copilot_sdk_connection_methods.md for details.

# --- Server Settings ---
# Local server port (Default: 4000)
PORT=4000
# When true in development the frontend will attempt to auto-connect to the local CLI
AUTO_CONNECT_CLI=true

# ═════════════════════════════════════════════════════════════=
# METHOD 1: Gemini CLI (ACP)
# ═════════════════════════════════════════════════════════════=
# Uses: cliPath: "gemini", cliArgs: "--experimental-acp"
# Requires: Gemini CLI installed and accessible in PATH
# Branch: gemini
# GEMINI_CLI_PATH=gemini
# GEMINI_CLI_ARGS=--experimental-acp

# ═════════════════════════════════════════════════════════════=
# METHOD 2: GitHub Copilot CLI (Default)
# ═════════════════════════════════════════════════════════════=
# Uses your existing GitHub Copilot subscription.
# No additional config needed — just run: git checkout v1 && npm start
# Your GitHub PAT for Models API access (optional for some local flows):
COPILOT_GITHUB_TOKEN=

# GitHub Models Inference API (Use base URL for CLI compatibility)
# COPILOT_API_URL=https://models.github.ai/inference
GITHUB_MODELS_API_VERSION=2022-11-28

# ═════════════════════════════════════════════════════════════=
# METHOD 3: Azure OpenAI BYOK (Bring Your Own Key)
# ═════════════════════════════════════════════════════════════=
# Uses: provider: { type: "azure", baseUrl, apiKey, azure: { apiVersion } }
# Branch: byok
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# ═════════════════════════════════════════════════════════════=
# METHOD 4: Remote Copilot CLI
# ═════════════════════════════════════════════════════════════=
# Connect to a running instance: copilot --acp --port 17817
# Branch: remote
# COPILOT_AGENT_PORT=17817

# ═════════════════════════════════════════════════════════════=
# Google Gemini REST API (Native, non-SDK)
# ═════════════════════════════════════════════════════════════=
# Optional: Direct Gemini REST calls (not through ACP SDK)
GEMINI_API_KEY=

# ═════════════════════════════════════════════════════════════=
# Model Configuration
# ═════════════════════════════════════════════════════════════=
# Available Models for UI dropdown (Comma-separated)
AVAILABLE_MODELS_GITHUB=gpt-5-mini,gpt-5.4-mini,gpt-5.4,claude sonnet 4.6
AVAILABLE_MODELS_GEMINI=gemini-2.5-flash,gemini-2.5-pro,gemini-3.1-pro,gemini-3.1-flash,gemini-3.1-flash-lite

# ═════════════════════════════════════════════════════════════=
# GitHub OAuth (Optional)
# ═════════════════════════════════════════════════════════════=
# Used for browser-based sign-in flow.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ═════════════════════════════════════════════════════════════=
# Optimization & Resilience
# ═════════════════════════════════════════════════════════════=
# Rate limiting: max requests per minute per IP (0 = unlimited)
# RATE_LIMIT_RPM=30
# RATE_LIMIT_ENABLED=true

# Idle client cleanup: minutes before idle SDK clients are released
# IDLE_CLEANUP_MINUTES=30

# Fallback models: comma-separated list tried sequentially on failure
# FALLBACK_MODELS=gpt-5-mini,gemini-2.5-flash

# Structured logging format: json | text
# LOG_FORMAT=json

# ═════════════════════════════════════════════════════════════=
# Response Customization
# ═════════════════════════════════════════════════════════════=
# DEFAULT_RESPONSE_LANGUAGE=繁體中文
# DEFAULT_PERSONA=文案高手...
