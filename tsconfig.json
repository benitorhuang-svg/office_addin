{
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "jsx": "react",
    "noEmitOnError": true,
    "outDir": "lib",
    "sourceMap": true,
    "target": "es5",
    "lib": [
      "es2015",
      "dom"
    ],
    "types": ["node", "office-js", "office-runtime"],
    "typeRoots": ["./node_modules/@types"],
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "lib",
    "lib-amd",
    "server"
  ],
  "ts-node": { 
    "files": true 
  }
}